APP_NAME=chatbot-api
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

# 로깅: app.core.logger (setup_logger + configure_root_logging). LOG_LEVEL 이 있으면 settings.log_level 보다 우선.
# LOG_LEVEL 이 있으면 settings.log_level 보다 우선.
# LOG_LEVEL=DEBUG
# LOG_DIR=logs

# new_main/docker-compose.ec2-1.yml 처럼 API·Redis를 **같은 compose**로 띄울 때: 서비스 이름 `redis`.
REDIS_URL=redis://redis:6379/0
# API만 호스트에서 돌리고 Redis는 compose로만 띄운 경우(포트 노출 시): redis://127.0.0.1:6379/0
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@postgres:5432/chatbot

# new_main RAG: 임베딩 HTTP API (예: EC2 embed 서버 — 포트는 배포에 맞게, 8765 또는 9000)
EMBEDDING_SERVICE_URL=http://15.135.211.14:8765
# 애매한 질문 의도 분류에 OpenAI 사용 (키 없으면 휴리스틱만)
INTENT_USE_OPENAI=true

# 짧거나 키워드로 축이 안 잡힐 때: LLM으로 3~5개 검색 쿼리 생성 후 RRF (키 없으면 휴리스틱 변형 쿼리)
# RETRIEVAL_MULTIQUERY_MIN=3
# RETRIEVAL_MULTIQUERY_MAX=5
# RETRIEVAL_MULTIQUERY_SHORT_CHARS=45
# RETRIEVAL_EXPAND_QUERIES_USE_OPENAI=true

# RAG 의도·답변 생성(/tools/embedding/api/search → run_vector_search). 임베딩 워커 .env 키와 별개로 메인에 필수.
OPENAI_API_KEY=
# OPENAI_BASE_URL=

LLM_QUEUE_NAME=queue:llm
EMBEDDING_QUEUE_NAME=queue:embedding
LLM_RESULT_PREFIX=result:llm:
LLM_STREAM_PREFIX=stream:llm:
EMBED_RESULT_PREFIX=result:embed:
