APP_NAME=chatbot-api
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000

REDIS_URL=redis://redis:6379/0
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@postgres:5432/chatbot

LLM_QUEUE_NAME=queue:llm
EMBEDDING_QUEUE_NAME=queue:embedding
LLM_RESULT_PREFIX=result:llm:
LLM_STREAM_PREFIX=stream:llm:
EMBED_RESULT_PREFIX=result:embed:
