# App
APP_NAME=Exmatch RAG Template
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=1
LOG_LEVEL=INFO
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_template
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/rag_template

# Redis
REDIS_URL=redis://redis:6379/0

# LLM / Embeddings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBED_PROVIDER=openai
EMBED_API_URL=

# Retrieval / Runtime
DEFAULT_EMBED_DIM=1536
DEFAULT_RETRIEVAL_TOP_K=5
