# App
APP_NAME=Exmatch RAG Template
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=1
RUN_MIGRATIONS=1
LOG_LEVEL=INFO
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rag_template
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/rag_template

# Redis
REDIS_URL=redis://redis:6379/0
LLM_QUEUE_NAME=queue:llm
EMBEDDING_QUEUE_NAME=queue:embedding
LLM_STREAM_PREFIX=stream:llm:
LLM_TRACE_PREFIX=trace:llm:
EMBED_RESULT_PREFIX=result:embed:

# LLM / Embeddings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBED_PROVIDER=openai
EMBED_API_URL=
WORKER_POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@db:5432/rag_template
WORKER_API_BASE_URL=http://api:8000
EMBED_BATCH_SIZE=32
MAX_RETRY=3
RETRIEVAL_MODEL_ID=Qwen/Qwen3-Embedding-0.6B
RETRIEVAL_DEVICE=cpu
RETRIEVAL_TOP_K=8

# Retrieval / Runtime
DEFAULT_EMBED_DIM=1536
DEFAULT_RETRIEVAL_TOP_K=5

# Local embedding inference server (API will proxy /embed/* to this)
# - If you run the embedding API on the host: http://127.0.0.1:8765 (Docker will auto-map to host.docker.internal)
# - If you run it inside Docker: set it to that container service URL
EMBEDDING_SERVICE_URL=http://127.0.0.1:8765
