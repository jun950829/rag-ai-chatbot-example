# --- 역할이 다른 프로세스 2개 (uvicorn 하나만 띄우면 Redis 큐는 그대로 쌓임) ---
#
# [A] 챗 비동기: 메인이 redis://… 의 list `queue:llm` 에 push 한 작업은 **워커**만 가져간다.
#     embedding 디렉터리에서 실행 (별도 로그 파일 권장):
#       nohup .venv/bin/python -m worker.main >> worker.log 2>&1 &
#
# [B] HTTP 임베딩 API: 메인의 EMBEDDING_SERVICE_URL 로 `/v1/embed/queries` 등을 때리는 건 **uvicorn** 한 개.
#       nohup .venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 8765 >> embedding-server.log 2>&1 &
#     두 프로세스는 독립이며 보통 모두 필요하다 (`cd embedding && bash install_deps.sh cpu` — `pip install -r requirements.txt` 만으로는 torch 가 없음).
#
# --- 배포(EC2 분리): 임베딩/워커 서버(EC2-2)에서 챗 큐까지 소비하려면 반드시 메인(API·Redis 가 있는 EC2-1) 을 가리켜야 함 ---
#
# 메인(API) 과 **동일** Redis 로 붙여야 한다. 검증: 브라우저·curl 로
#   http://<EC2-1>:8000/chat/queue/status → llm_queue_length
# 클러스터가 같은 Redis 에 붙었다면 채팅 적재 후 이 숫자가 잠깐 올라갔다 내려간다.
# 임베딩 EC2에서 REDIS 호스트가 `redis`·`localhost` 이면 대부분 틀림(Compose 이름 / 로컬 전용).
REDIS_URL=redis://<EC2-1-PRIVATE-IP-OR-PUBLIC>:6379/0
#
# /tools/embedding/api/search 등 HTTP 호출용 — docker 서비스명 api 는 EC2-2 에서 접근 불가
API_BASE_URL=http://<EC2-1-PRIVATE-IP-OR-PUBLIC>:8000

POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@<EC2-1-PRIVATE-IP-OR-PUBLIC>:5432/chatbot

# 워커: 휴리스틱이 general 일 때 메인과 동일 FAQ 힌트가 없으면 gpt-4o-mini 라우팅 재판 후 검색 API 분기까지 보냄
OPENAI_API_KEY=
# OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
WORKER_GENERAL_FALLBACK_OPENAI=true

LLM_QUEUE_NAME=queue:llm
LLM_STREAM_PREFIX=stream:llm:
LLM_TRACE_PREFIX=trace:llm:
LLM_RESULT_PREFIX=result:llm:
EMBEDDING_QUEUE_NAME=queue:embedding
EMBED_RESULT_PREFIX=result:embed:

EMBED_BATCH_SIZE=32
MAX_RETRY=3

# (선택) Sentence Transformers 3.2+ 추론 백엔드: onnx / openvino 등 — `pip install "sentence-transformers[onnx]"` 등 추가 필요.
# 디스크 절감의 본질은 여전히 CPU 전용 PyTorch 휠(`install_deps.sh cpu`); PyPI 메타데이터상 torch 는 필수 의존성이다.
# SENTENCE_TRANSFORMERS_BACKEND=onnx
