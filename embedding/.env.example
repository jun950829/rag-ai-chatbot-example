# --- 배포(EC2 분리): 임베딩/워커 서버(EC2-2)에서 챗 큐까지 소비하려면 반드시 메인(API·Redis 가 있는 EC2-1) 을 가리켜야 함 ---
#
# 메인 컨테이너(main-api) 의 REDIS_URL 과 동일한 Redis (챗봇 /chat 이 rpush 하는 큐 위치)
REDIS_URL=redis://<EC2-1-PRIVATE-IP-OR-PUBLIC>:6379/0
#
# /tools/embedding/api/search 등 HTTP 호출용 — docker 서비스명 api 는 EC2-2 에서 접근 불가
API_BASE_URL=http://<EC2-1-PRIVATE-IP-OR-PUBLIC>:8000

POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@<EC2-1-PRIVATE-IP-OR-PUBLIC>:5432/chatbot

LLM_QUEUE_NAME=queue:llm
LLM_STREAM_PREFIX=stream:llm:
LLM_TRACE_PREFIX=trace:llm:
LLM_RESULT_PREFIX=result:llm:
EMBEDDING_QUEUE_NAME=queue:embedding
EMBED_RESULT_PREFIX=result:embed:

EMBED_BATCH_SIZE=32
MAX_RETRY=3
